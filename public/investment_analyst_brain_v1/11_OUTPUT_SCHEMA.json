{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Investment Analyst Brain v1.1 Canonical Output",
  "type": "object",
  "required": [
    "methodologyVersion",
    "language",
    "company",
    "executiveDecision",
    "classification",
    "businessQuality",
    "modelSelection",
    "forecastAssumptions",
    "valuationResults",
    "scenarios",
    "catalysts",
    "risks",
    "whatChangesMyMind",
    "finalDecision",
    "monitoringChecklist",
    "dashboardExport"
  ],
  "properties": {
    "methodologyVersion": { "const": "investment-analyst-brain-v1.1-canonical" },
    "language": { "enum": ["ar", "en"] },
    "company": {
      "type": "object",
      "required": ["ticker", "name", "valuationDate", "currentPrice", "currency"]
    },
    "executiveDecision": {
      "type": "object",
      "required": ["recommendation", "confidence", "investmentScore", "currentPrice", "fairValue", "upsideDownside", "why"]
    },
    "classification": {
      "type": "object",
      "required": ["classification", "evidence", "suitableModels", "excludedModels", "unsupportedModels", "confidence"]
    },
    "businessQuality": {
      "type": "object",
      "required": ["score", "rating", "confidence", "components", "explanation"]
    },
    "modelSelection": {
      "type": "object",
      "required": ["selectedModels", "excludedModels", "unsupportedModels", "weightChecks", "externalReferenceWeight"]
    },
    "forecastAssumptions": {
      "type": "object",
      "required": ["sourcePriority", "yearlyForecast", "wacc", "sensitivity", "confidence"]
    },
    "valuationResults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "role", "value", "weight", "confidence", "source", "assumptions", "fairValue", "explanation"]
      }
    },
    "scenarios": {
      "type": "object",
      "required": ["Conservative", "Base", "Optimistic", "Exceptional"]
    },
    "catalysts": { "type": "array" },
    "risks": { "type": "array" },
    "whatChangesMyMind": {
      "type": "object",
      "required": ["items", "biggestAssumption", "upgradeTrigger", "downgradeTrigger", "thesisBreak", "revaluationRequired"]
    },
    "finalDecision": {
      "type": "object",
      "required": ["decision", "why", "whyNot", "biggestAssumption", "whatChangesTheDecision", "policyGates"]
    },
    "monitoringChecklist": {
      "type": "array",
      "minItems": 5,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["metric", "currentValue", "expectedRange", "upgradeTrigger", "downgradeTrigger", "thesisBreak", "revaluationEvent"]
      }
    },
    "dashboardExport": {
      "type": "object",
      "required": ["approvedOnly", "exported", "ticker", "recommendation", "currentPrice", "fairValue", "upsideDownside", "investmentScore", "confidence"]
    }
  }
}
